% Minimal ICLR-style conference formatting (compatible with pdflatex).
% Replace with the official ICLR 2025/2026 style file before submission.
\usepackage{eso-pic}
\usepackage{fancyhdr}
\usepackage{natbib}
\usepackage[margin=1in]{geometry}

\renewcommand{\headrulewidth}{0pt}
\fancyhead{}
\fancyfoot{}

\newcommand{\iclrfinalcopy}{%
  \AddToShipoutPicture{\includegraphics[width=\paperwidth,height=\paperheight]{}}%
}

\newcommand{\@noticestring}{%
  Submitted to the International Conference on Learning Representations (ICLR).%
}

\newcommand{\notice@string}{\@noticestring}

\newcommand{\maketitle@iclr}{%
  \begin{center}
    {\LARGE\bfseries\@title\par}
    \vspace{1.0em}
    {\large\@author\par}
    \vspace{0.5em}
    {\small\textit{\notice@string}\par}
  \end{center}
  \vspace{1.5em}
}

\let\oldmaketitle\maketitle
\renewcommand{\maketitle}{\maketitle@iclr}
